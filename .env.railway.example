# Railway Environment Variables Configuration
# Copy this file and set the values in Railway Dashboard -> Variables

# ===========================================
# DATABASE (Required)
# ===========================================
# Railway will auto-generate DATABASE_URL if you add a PostgreSQL database
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@host:5432/database

# PostgreSQL connection details (auto-populated by Railway if using their Postgres)
PGHOST=your-pg-host
PGPORT=5432
PGUSER=your-pg-user
PGPASSWORD=your-pg-password
PGDATABASE=your-database-name

# ===========================================
# SESSION (Required)
# ===========================================
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-random-session-secret-min-32-characters

# ===========================================
# COMPANIES HOUSE API (Optional)
# ===========================================
# Get your API key from: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=your-companies-house-api-key

# ===========================================
# APPLICATION (Auto-set by Railway)
# ===========================================
# Railway automatically sets PORT - do not override
# NODE_ENV is set in the start command

# ===========================================
# IMPORTANT NOTES
# ===========================================
# 1. In Railway Dashboard, go to your service -> Variables
# 2. Add each variable with its value
# 3. For DATABASE_URL, if using Railway's PostgreSQL:
#    - Add PostgreSQL from the "New" menu
#    - Reference it with: ${{Postgres.DATABASE_URL}}
# 4. The SESSION_SECRET should be a strong random string
# 5. COMPANIES_HOUSE_API_KEY is optional but recommended for company data sync
